# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
# Host-based URL used by local tooling and seed scripts.
# The docker-compose.yml exposes Postgres on host port 5433 to avoid clashing
# with any existing local Postgres. If you change the mapping, update these.
DATABASE_URL=postgresql+asyncpg://keystone:keystone@localhost:5433/keystone
# Sync variant for scripts / migrations that prefer psycopg2.
DATABASE_URL_SYNC=postgresql://keystone:keystone@localhost:5433/keystone

# --- Google DeepMind (Gemini) ---
GEMINI_API_KEY=replace-me
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.0-pro
GEMINI_EMBED_MODEL=text-embedding-004

# --- Tavily ---
TAVILY_API_KEY=replace-me

# --- Entire (approval layer) ---
ENTIRE_API_KEY=replace-me
ENTIRE_BASE_URL=https://api.entire.example

# --- Pioneer / Fastino (learning layer) ---
PIONEER_API_KEY=replace-me

# --- Aikido (security scan badge) ---
AIKIDO_API_KEY=replace-me

# --- Gradium (optional stretch TTS) ---
GRADIUM_API_KEY=replace-me

# --- IMAP (Phase 1 email ingestion) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=demo@example.com
IMAP_PASSWORD=replace-me
IMAP_MAILBOX=INBOX

# --- Slack webhook (Phase 2) ---
SLACK_SIGNING_SECRET=replace-me

# --- Mock ERP (Phase 2) ---
MOCK_ERP_URL=http://localhost:8001
